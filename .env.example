# ═══════════════════════════════════════════════════════════════════════════
# Forecast Studio — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Skopiuj do .env i uzupełnij wartości:
#   cp .env.example .env
#
# Zmienne poniżej są automatycznie ładowane przez docker-compose
# oraz przez backend (Pydantic Settings).
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM API (OpenAI-compatible) ───────────────────────────────────────────
# Prefer LLM_*; legacy DEEPSEEK_* / OPENAI_API_KEY still work — see CONFIG.md
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=openai-compatible

# Legacy (optional — used if LLM_API_KEY is empty)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Langfuse (local observability) ───────────────────────────────────────
# Keys must match your Langfuse project (Settings → API keys).
# If you run the full docker-compose stack, backend + worker get keys and
# LANGFUSE_BASE_URL=http://langfuse-web:3000 from compose — do not override
# with localhost from inside containers.
#
# Backend on host (uv), Langfuse in Docker (port 3001 on host):
# LANGFUSE_PUBLIC_KEY=pk-lf-forecaster-local
# LANGFUSE_SECRET_KEY=sk-lf-forecaster-local
# LANGFUSE_BASE_URL=http://localhost:3001

# ── Database (only needed when running outside docker-compose) ───────────
# DATABASE_URL=postgresql+asyncpg://forecaster:forecaster_dev_password@localhost:5432/forecaster

# ── Redis ────────────────────────────────────────────────────────────────
# If host port 6379 is already taken (e.g. local Redis), avoid bind errors:
# REDIS_HOST_PORT=6380
# (Inside Docker, services still use redis:6379 — only the published host port changes.)
#
# When running backend on host against compose Redis:
# REDIS_URL=redis://localhost:6379/0
# If you set REDIS_HOST_PORT=6380, use that port in REDIS_URL instead.

# ── MLflow (Docker host port — macOS AirPlay often uses 5000; try 5001) ───
# MLFLOW_HOST_PORT=5001

# ── Frontend (Next.js — npm run dev on host; Docker sets these in compose) ─
# NEXT_PUBLIC_API_URL=http://localhost:8000
# If you set MLFLOW_HOST_PORT above, match MLflow here (Compose wires this when building)
# NEXT_PUBLIC_MLFLOW_URL=http://localhost:5001
# NEXT_PUBLIC_DAGSTER_URL=http://localhost:3005

# ── MLflow (tracking URI when running jobs on host against compose MLflow) ─
# MLFLOW_TRACKING_URI=http://localhost:5001

# ── Security ─────────────────────────────────────────────────────────────
# SECRET_KEY=change-me-to-random-string

# ── Azure (optional — for blob storage or Azure deployment) ──────────────
# AZURE_APP_ID=
# AZURE_TENANT_ID=
# AZURE_PASSWORD=
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_ACCOUNT_KEY=
